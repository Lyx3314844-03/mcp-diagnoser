  "description": "Comprehensive MCP diagnostic tool with advanced multi-engine search, anti-bot bypass, and package diagnosis",
  "main": "dist/index.js",
  "bin": {
    "mcp-diagnoser": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
