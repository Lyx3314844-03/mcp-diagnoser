    "prepublishOnly": "npm run build",
    "postinstall": "node scripts/postinstall.js",
    "install:linux": "bash scripts/install.sh",
    "install:macos": "bash scripts/install.sh"
  },
  "os": [
    "win32",
    "linux",
    "darwin"
  ],
  "keywords": [
    "mcp",
    "diagnostic",
    "troubleshooting",
    "model-context-protocol",
    "playwright",
    "package-manager",
    "npm",
    "pip",
    "cargo",
    "web-search",
    "crawler",
    "mcp-server"
  ],
  "author": "Lan <3314844@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/mcp-diagnoser.git"
  },
  "bugs": {
    "url": "https://github.com/YOUR_USERNAME/mcp-diagnoser/issues"
  },
  "homepage": "https://github.com/YOUR_USERNAME/mcp-diagnoser#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "execa": "^8.0.1",
    "fs-extra": "^11.2.0",
    "ora": "^5.4.1",
    "semver": "^7.5.4",
    "table": "^6.8.1",
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.5",
    "@types/semver": "^7.5.6",
    "jest": "^29.7.0",
    "playwright": "^1.58.2",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "scripts",
    "README.md",
    "LICENSE"
